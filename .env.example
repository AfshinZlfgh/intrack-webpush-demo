# inTrack SDK Keys
# Find at: dash.intrack.ir → Settings → SDK → Initialize
NEXT_PUBLIC_INTRACK_APP_KEY=your_app_key_here
NEXT_PUBLIC_INTRACK_AUTH_KEY=your_auth_key_here
NEXT_PUBLIC_INTRACK_PUBLIC_KEY=your_public_key_here

# "production" or "stage"
NEXT_PUBLIC_INTRACK_ENV=production

# Set to "true" to enable inTrack SDK debug logging in the browser console
NEXT_PUBLIC_INTRACK_DEBUG=false

# Firebase credentials are entered at runtime in the browser UI (Mode B page).
# No Firebase env vars are needed here.
